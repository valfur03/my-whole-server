{
  "uid": "infra-containers",
  "title": "10-Infra — Containers",
  "tags": ["homelab", "infra", "containers"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "label": "Container",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "qryType": 1, "query": "label_values(container_last_seen{name!=\"\"}, name)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "definition": "label_values(container_last_seen{name!=\"\"}, name)",
        "regex": "",
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] }
      }
    ]
  },
  "links": [
    { "title": "Home", "type": "link", "icon": "home", "url": "/d/home-server-health", "tooltip": "00-Home — Server health", "targetBlank": false, "keepTime": true, "includeVars": false }
  ],
  "annotations": {
    "list": [
      {
        "name": "Deploys",
        "datasource": { "type": "loki", "uid": "loki" },
        "enable": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "expr": "{compose_service=\"doco-cd\"} |~ \"(?i)deploy.*success\"",
        "target": { "expr": "{compose_service=\"doco-cd\"} |~ \"(?i)deploy.*success\"", "refId": "Anno" }
      }
    ]
  },
  "panels": [
    {
      "id": 600,
      "type": "row",
      "title": "Headline",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Running containers",
      "description": "Distinct container names cAdvisor has observed in the last scrape.",
      "gridPos": { "x": 0, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "count(container_last_seen{name!=\"\"})" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total CPU (cores)",
      "description": "Sum of CPU usage across all containers, expressed in fractional cores. 1.0 = one full core in use.",
      "gridPos": { "x": 5, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(container_cpu_usage_seconds_total{name!=\"\"}[5m]))" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 2 }, { "color": "red", "value": 4 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total memory",
      "description": "Sum of working-set memory across all containers — closer to 'real' memory pressure than RSS.",
      "gridPos": { "x": 10, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(container_memory_working_set_bytes{name!=\"\"})" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Restarts (1 h)",
      "description": "Number of container restarts in the last hour, summed across containers. `changes(container_last_seen[1h])` counts each time the last-seen timestamp resets.",
      "gridPos": { "x": 15, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(changes(container_last_seen{name!=\"\"}[1h]))" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "OOM kills (24 h)",
      "description": "Containers killed by the kernel for OOM in the last 24 h. Should be zero.",
      "gridPos": { "x": 19, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(increase(container_oom_events_total{name!=\"\"}[24h])) or vector(0)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 601,
      "type": "row",
      "title": "Top 10 — CPU & memory",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Top 10 by CPU",
      "description": "Top 10 containers by 5-minute CPU rate. Unit: fractional cores. 1.0 = one core fully utilised by this container.",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "topk(10, sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"$container\", name!=\"\"}[$__rate_interval])))", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 3,
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Top 10 by memory (working set)",
      "description": "Working-set bytes is the memory cgroup's 'cannot be reclaimed under pressure' figure — better than RSS for spotting real memory hogs.",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "topk(10, sum by (name) (container_memory_working_set_bytes{name=~\"$container\", name!=\"\"}))", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 602,
      "type": "row",
      "title": "Top 10 — network I/O",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Top 10 by network RX",
      "description": "Per-container ingress bytes/sec summed across interfaces.",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "topk(10, sum by (name) (rate(container_network_receive_bytes_total{name=~\"$container\", name!=\"\"}[$__rate_interval])))", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Top 10 by network TX",
      "description": "Per-container egress bytes/sec.",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "topk(10, sum by (name) (rate(container_network_transmit_bytes_total{name=~\"$container\", name!=\"\"}[$__rate_interval])))", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 603,
      "type": "row",
      "title": "Per-container USE summary",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 }
    },
    {
      "id": 10,
      "type": "table",
      "title": "Per-container CPU / memory / network / restarts",
      "description": "One row per container. Sort by CPU or memory to find the heavy hitter.",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "Cpu", "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"$container\", name!=\"\"}[5m]))", "instant": true, "format": "table" },
        { "refId": "Mem", "expr": "sum by (name) (container_memory_working_set_bytes{name=~\"$container\", name!=\"\"})", "instant": true, "format": "table" },
        { "refId": "Rx", "expr": "sum by (name) (rate(container_network_receive_bytes_total{name=~\"$container\", name!=\"\"}[5m]))", "instant": true, "format": "table" },
        { "refId": "Tx", "expr": "sum by (name) (rate(container_network_transmit_bytes_total{name=~\"$container\", name!=\"\"}[5m]))", "instant": true, "format": "table" },
        { "refId": "Restarts", "expr": "sum by (name) (changes(container_last_seen{name=~\"$container\", name!=\"\"}[1h]))", "instant": true, "format": "table" },
        { "refId": "Oom", "expr": "sum by (name) (increase(container_oom_events_total{name=~\"$container\", name!=\"\"}[24h]))", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "joinByField", "options": { "byField": "name", "mode": "outer" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true, "Time 6": true },
            "renameByName": {
              "name": "Container",
              "Value #Cpu": "CPU (cores)",
              "Value #Mem": "Memory",
              "Value #Rx": "RX",
              "Value #Tx": "TX",
              "Value #Restarts": "Restarts (1h)",
              "Value #Oom": "OOM (24h)"
            },
            "indexByName": { "Container": 0, "CPU (cores)": 1, "Memory": 2, "RX": 3, "TX": 4, "Restarts (1h)": 5, "OOM (24h)": 6 }
          }
        },
        { "id": "sortBy", "options": { "fields": {}, "sort": [{ "field": "CPU (cores)", "desc": true }] } }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "CPU (cores)" }, "properties": [{ "id": "unit", "value": "short" }, { "id": "decimals", "value": 3 }, { "id": "custom.cellOptions", "value": { "type": "color-text" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.5 }, { "color": "red", "value": 1.5 }] } }] },
          { "matcher": { "id": "byName", "options": "Memory" }, "properties": [{ "id": "unit", "value": "bytes" }] },
          { "matcher": { "id": "byName", "options": "RX" }, "properties": [{ "id": "unit", "value": "Bps" }] },
          { "matcher": { "id": "byName", "options": "TX" }, "properties": [{ "id": "unit", "value": "Bps" }] },
          { "matcher": { "id": "byName", "options": "Restarts (1h)" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] } }] },
          { "matcher": { "id": "byName", "options": "OOM (24h)" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }] }
        ]
      },
      "options": { "showHeader": true, "footer": { "show": false } }
    },
    {
      "id": 604,
      "type": "row",
      "title": "Restart timeline (collapsed)",
      "collapsed": true,
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 1 },
      "panels": [
        {
          "id": 11,
          "type": "timeseries",
          "title": "Restart events — per container",
          "description": "`changes(container_last_seen[5m])` produces a small step every time a container restarts. Use this to correlate restart bursts with errors or deploys.",
          "gridPos": { "x": 0, "y": 37, "w": 24, "h": 8 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            { "refId": "A", "expr": "changes(container_last_seen{name=~\"$container\", name!=\"\"}[5m]) > 0", "legendFormat": "{{name}}" }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "custom": { "drawStyle": "points", "lineWidth": 1, "fillOpacity": 0, "pointSize": 6 }
            },
            "overrides": []
          },
          "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["sum", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
        }
      ]
    }
  ]
}
