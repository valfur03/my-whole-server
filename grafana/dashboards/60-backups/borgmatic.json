{
  "uid": "backups-borgmatic",
  "title": "60-Backups — Borgmatic",
  "tags": ["homelab", "backups", "borgmatic"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "editable": false,
  "graphTooltip": 1,
  "refresh": "1m",
  "time": { "from": "now-7d", "to": "now" },
  "templating": { "list": [] },
  "annotations": {
    "list": [
      {
        "name": "Deploys",
        "datasource": { "type": "loki", "uid": "loki" },
        "enable": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "expr": "{compose_service=\"doco-cd\"} |~ \"(?i)deploy.*success\"",
        "target": { "expr": "{compose_service=\"doco-cd\"} |~ \"(?i)deploy.*success\"", "refId": "Anno" }
      }
    ]
  },
  "panels": [
    {
      "id": 400,
      "type": "row",
      "title": "Status — from node-exporter textfile-collector hook",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Oldest last-success across configs",
      "description": "`max(time() - borgmatic_last_success_timestamp_seconds)` — how stale the most-overdue config is. Green < 24 h, yellow 24–48 h, red beyond.",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "max(time() - borgmatic_last_success_timestamp_seconds)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 86400 }, { "color": "red", "value": 172800 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Configs OK",
      "description": "Number of configs whose last run succeeded over total configs reporting. `sum(borgmatic_last_run_status) / count(borgmatic_last_run_status)`.",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(borgmatic_last_run_status)", "legendFormat": "ok" },
        { "refId": "B", "expr": "count(borgmatic_last_run_status)", "legendFormat": "total" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Last run (any config)",
      "description": "Time since *any* config's last run finished (success or failure). Useful for confirming the daily cron actually fires.",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "min(time() - borgmatic_last_run_timestamp_seconds)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 86400 }, { "color": "red", "value": 172800 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 4,
      "type": "table",
      "title": "Per-config status",
      "description": "One row per borgmatic config. Sort by `last_success` ascending to spot stale entries first.",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "borgmatic_last_run_timestamp_seconds", "legendFormat": "{{config}}", "format": "table", "instant": true },
        { "refId": "B", "expr": "borgmatic_last_success_timestamp_seconds", "legendFormat": "{{config}}", "format": "table", "instant": true },
        { "refId": "C", "expr": "borgmatic_last_run_status", "legendFormat": "{{config}}", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "joinByField", "options": { "byField": "config", "mode": "outer" } },
        { "id": "organize", "options": { "excludeByName": { "Time 1": true, "Time 2": true, "Time 3": true, "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "job 1": true, "job 2": true, "job 3": true, "instance 1": true, "instance 2": true, "instance 3": true }, "renameByName": { "config": "config", "Value #A": "last_run", "Value #B": "last_success", "Value #C": "status" } } }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "last_run" }, "properties": [{ "id": "unit", "value": "dateTimeAsLocal" }] },
          { "matcher": { "id": "byName", "options": "last_success" }, "properties": [{ "id": "unit", "value": "dateTimeAsLocal" }] },
          { "matcher": { "id": "byName", "options": "status" }, "properties": [
            { "id": "mappings", "value": [{ "type": "value", "options": { "0": { "text": "FAIL", "color": "red" }, "1": { "text": "OK", "color": "green" } } }] },
            { "id": "custom.cellOptions", "value": { "type": "color-text" } }
          ] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "last_success", "desc": false }] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Time since last success — per config (last 7 days)",
      "description": "Sawtooth pattern: ramps up by 1 second per second between runs, drops to ~0 when a successful run completes. A flat line that keeps climbing = that config has stopped succeeding.",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "time() - borgmatic_last_success_timestamp_seconds", "legendFormat": "{{config}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 86400 }, { "color": "red", "value": 172800 }] }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } }
    },
    {
      "id": 401,
      "type": "row",
      "title": "Log-derived — supplementary (errors / activity / raw lines)",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 1 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Errors per hour — last 7 days",
      "description": "Hourly count of error-level lines from borgmatic. Should be flat at zero between scheduled runs.",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum(count_over_time({compose_service=\"borgmatic\"} |~ \"(?i)error|exception|fatal\" [1h]))", "legendFormat": "errors" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 80 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false }, "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Borgmatic — summary / error log",
      "description": "Lines matching `summary|error|exception|fatal`. Read top-to-bottom to follow a recent run.",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "{compose_service=\"borgmatic\"} |~ \"(?i)summary|error|exception|fatal\"" }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
