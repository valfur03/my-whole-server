{
  "uid": "backups-borgmatic",
  "title": "60-Backups — Borgmatic (Loki)",
  "tags": ["homelab", "backups", "borgmatic", "transitional"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "graphTooltip": 1,
  "refresh": "1m",
  "time": { "from": "now-7d", "to": "now" },
  "templating": { "list": [] },
  "annotations": {
    "list": [
      {
        "name": "Deploys",
        "datasource": { "type": "loki", "uid": "loki" },
        "enable": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "expr": "{compose_service=\"doco-cd\"} |~ \"(?i)deploy.*success\"",
        "target": { "expr": "{compose_service=\"doco-cd\"} |~ \"(?i)deploy.*success\"", "refId": "Anno" }
      }
    ]
  },
  "panels": [
    {
      "id": 400,
      "type": "row",
      "title": "Status — derived from Loki until textfile-collector hook is in place",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Backups completed (24 h)",
      "description": "Borgmatic completion lines in the last 24 hours. Green ≥ 1, red = 0 (cycle missed — borgmatic runs daily at 02:00 Europe/Paris per compose.yaml). Regex matches both `summary errors: 0` (borg summary line) and free-text completion phrases — verify on first run.",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 5 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum(count_over_time({compose_service=\"borgmatic\"} |~ \"(?i)summary.*errors:\\\\s*0|backup.*(complete|success)\" [24h]))", "queryType": "instant" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Errors (24 h)",
      "description": "Borgmatic log lines matching `error|exception|fatal` in the last 24 h.",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 5 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum(count_over_time({compose_service=\"borgmatic\"} |~ \"(?i)error|exception|fatal\" [24h]))", "queryType": "instant" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Backup activity (24 h)",
      "description": "Total log lines from borgmatic in 24 h — proxy for 'did anything run at all?'",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 5 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum(count_over_time({compose_service=\"borgmatic\"}[24h]))", "queryType": "instant" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Completions per hour — last 7 days",
      "description": "Hourly count of borgmatic completion lines. Expected pattern: one spike per day around 02:00 Europe/Paris.",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum(count_over_time({compose_service=\"borgmatic\"} |~ \"(?i)summary.*errors:|backup.*(complete|success)\" [1h]))", "legendFormat": "completions" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 80 },
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false }, "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Errors per hour — last 7 days",
      "description": "Hourly count of error-level lines from borgmatic. Should be flat at zero between scheduled runs.",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum(count_over_time({compose_service=\"borgmatic\"} |~ \"(?i)error|exception|fatal\" [1h]))", "legendFormat": "errors" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 80 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false }, "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Borgmatic — summary / error log",
      "description": "Lines matching `summary|error|exception|fatal`. Read top-to-bottom to follow a recent run.",
      "gridPos": { "x": 0, "y": 19, "w": 24, "h": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "{compose_service=\"borgmatic\"} |~ \"(?i)summary|error|exception|fatal\"" }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
