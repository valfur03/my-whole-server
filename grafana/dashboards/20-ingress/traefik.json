{
  "uid": "ingress-traefik",
  "title": "20-Ingress — Traefik & FRPS",
  "tags": ["homelab", "ingress", "traefik", "frps"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "editable": false,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "router",
        "type": "query",
        "label": "Router",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "qryType": 1, "query": "label_values(traefik_router_requests_total, router)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "definition": "label_values(traefik_router_requests_total, router)",
        "regex": "",
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] }
      }
    ]
  },
  "links": [
    { "title": "Home", "type": "link", "icon": "home", "url": "/d/home-server-health", "tooltip": "00-Home — Server health", "targetBlank": false, "keepTime": true, "includeVars": false }
  ],
  "annotations": {
    "list": [
      {
        "name": "Deploys",
        "datasource": { "type": "loki", "uid": "loki" },
        "enable": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "expr": "{compose_service=\"doco-cd\"} | json | msg=\"job completed successfully\" | elapsed_time > 10s",
        "target": { "expr": "{compose_service=\"doco-cd\"} | json | msg=\"job completed successfully\" | elapsed_time > 10s", "refId": "Anno" }
      }
    ]
  },
  "panels": [
    {
      "id": 300,
      "type": "row",
      "title": "RED — front door",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Requests / sec",
      "description": "Total request rate across all routers.",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(traefik_router_requests_total[$__rate_interval]))" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2, "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "5xx rate",
      "description": "Share of requests answered with a 5xx code in the last 5 m. Green < 1 %, orange 1–5 %, red beyond. Same query becomes the alert.",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(traefik_router_requests_total{code=~\"5..\"}[5m])) / sum(rate(traefik_router_requests_total[5m]))" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.01 }, { "color": "red", "value": 0.05 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "4xx rate",
      "description": "Client-side errors. High values often signal scanners or misconfigured clients more than real bugs.",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(traefik_router_requests_total{code=~\"4..\"}[5m])) / sum(rate(traefik_router_requests_total[5m]))" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "orange", "value": 0.20 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p95 latency",
      "description": "95th-percentile request duration across all routers, computed from histogram buckets over the last 5 m.",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(traefik_router_request_duration_seconds_bucket[5m])))" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 3 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 301,
      "type": "row",
      "title": "Traffic & errors per router",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request rate — top 10 routers",
      "description": "Top 10 routers by request rate over the panel range.",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "topk(10, sum by (router) (rate(traefik_router_requests_total{router=~\"$router\"}[$__rate_interval])))", "legendFormat": "{{router}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "5xx rate by router",
      "description": "Per-router 5xx request rate — find the offender behind a flat overall ratio.",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum by (router) (rate(traefik_router_requests_total{router=~\"$router\", code=~\"5..\"}[$__rate_interval])) > 0", "legendFormat": "{{router}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 302,
      "type": "row",
      "title": "Latency per router",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "p95 latency by router",
      "description": "p95 derived from `traefik_router_request_duration_seconds_bucket`. Filter via the `$router` variable to keep it readable when many routers are live.",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, router) (rate(traefik_router_request_duration_seconds_bucket{router=~\"$router\"}[5m])))", "legendFormat": "{{router}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 0, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "p99 latency by router",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.99, sum by (le, router) (rate(traefik_router_request_duration_seconds_bucket{router=~\"$router\"}[5m])))", "legendFormat": "{{router}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 0, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 303,
      "type": "row",
      "title": "Per-router RED summary",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Per-router rate / error% / p95 / p99",
      "description": "One row per router. Sort by 5xx% or p95 to spot the worst offenders quickly. RED method in one screen.",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "Rate", "expr": "sum by (router) (rate(traefik_router_requests_total{router=~\"$router\"}[5m]))", "instant": true, "format": "table" },
        { "refId": "Err5", "expr": "sum by (router) (rate(traefik_router_requests_total{router=~\"$router\", code=~\"5..\"}[5m])) / sum by (router) (rate(traefik_router_requests_total{router=~\"$router\"}[5m]))", "instant": true, "format": "table" },
        { "refId": "Err4", "expr": "sum by (router) (rate(traefik_router_requests_total{router=~\"$router\", code=~\"4..\"}[5m])) / sum by (router) (rate(traefik_router_requests_total{router=~\"$router\"}[5m]))", "instant": true, "format": "table" },
        { "refId": "P95", "expr": "histogram_quantile(0.95, sum by (le, router) (rate(traefik_router_request_duration_seconds_bucket{router=~\"$router\"}[5m])))", "instant": true, "format": "table" },
        { "refId": "P99", "expr": "histogram_quantile(0.99, sum by (le, router) (rate(traefik_router_request_duration_seconds_bucket{router=~\"$router\"}[5m])))", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "joinByField", "options": { "byField": "router", "mode": "outer" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true
            },
            "renameByName": {
              "router": "Router",
              "Value #Rate": "Req/s",
              "Value #Err5": "5xx %",
              "Value #Err4": "4xx %",
              "Value #P95": "p95",
              "Value #P99": "p99"
            },
            "indexByName": { "Router": 0, "Req/s": 1, "5xx %": 2, "4xx %": 3, "p95": 4, "p99": 5 }
          }
        },
        { "id": "sortBy", "options": { "fields": {}, "sort": [{ "field": "5xx %", "desc": true }] } }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Req/s" }, "properties": [{ "id": "unit", "value": "reqps" }, { "id": "decimals", "value": 2 }] },
          { "matcher": { "id": "byName", "options": "5xx %" }, "properties": [{ "id": "unit", "value": "percentunit" }, { "id": "decimals", "value": 3 }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.01 }, { "color": "red", "value": 0.05 }] } }, { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } }] },
          { "matcher": { "id": "byName", "options": "4xx %" }, "properties": [{ "id": "unit", "value": "percentunit" }, { "id": "decimals", "value": 3 }] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [{ "id": "unit", "value": "s" }, { "id": "decimals", "value": 2 }] },
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "unit", "value": "s" }, { "id": "decimals", "value": 2 }] }
        ]
      },
      "options": { "showHeader": true, "footer": { "show": false } }
    },
    {
      "id": 304,
      "type": "row",
      "title": "Top-N / breakdown",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 34, "w": 24, "h": 1 }
    },
    {
      "id": 10,
      "type": "bargauge",
      "title": "Top 10 routers — last 24 h volume",
      "description": "Total requests served per router over the trailing 24 h.",
      "gridPos": { "x": 0, "y": 35, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "topk(10, sum by (router) (increase(traefik_router_requests_total{router=~\"$router\"}[24h])))", "legendFormat": "{{router}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "continuous-BlPu" } },
        "overrides": []
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Status-code class distribution",
      "description": "Stacked rate by status-code class (2xx / 3xx / 4xx / 5xx).",
      "gridPos": { "x": 12, "y": 35, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "S2", "expr": "sum(rate(traefik_router_requests_total{code=~\"2..\"}[$__rate_interval]))", "legendFormat": "2xx" },
        { "refId": "S3", "expr": "sum(rate(traefik_router_requests_total{code=~\"3..\"}[$__rate_interval]))", "legendFormat": "3xx" },
        { "refId": "S4", "expr": "sum(rate(traefik_router_requests_total{code=~\"4..\"}[$__rate_interval]))", "legendFormat": "4xx" },
        { "refId": "S5", "expr": "sum(rate(traefik_router_requests_total{code=~\"5..\"}[$__rate_interval]))", "legendFormat": "5xx" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 40, "showPoints": "never", "stacking": { "mode": "normal" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "2xx" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "3xx" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 305,
      "type": "row",
      "title": "Entrypoints & internals",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 44, "w": 24, "h": 1 }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Request rate by entrypoint",
      "description": "Per-entrypoint rate (http on :80, https on :443). The redirect from http→https shows here.",
      "gridPos": { "x": 0, "y": 45, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum by (entrypoint) (rate(traefik_entrypoint_requests_total[$__rate_interval]))", "legendFormat": "{{entrypoint}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 310,
      "type": "stat",
      "title": "Time since last reload",
      "description": "Age of the last successful dynamic-config reload (from `traefik_config_last_reload_success`, which is a Unix timestamp). Long ages are normal when nothing is deploying.",
      "gridPos": { "x": 12, "y": 45, "w": 4, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "time() - traefik_config_last_reload_success" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Config reload status (15 m)",
      "description": "OK if there were no failed dynamic-config reloads in the last 15 min, FAIL otherwise. A failure usually means a malformed docker label.",
      "gridPos": { "x": 16, "y": 45, "w": 4, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "increase(traefik_config_reloads_failure_total[15m]) == bool 0" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "FAIL" }, "1": { "text": "OK" } } }]
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Config reloads (24 h)",
      "description": "Total config reloads in the last 24 h — should bump with every doco-cd deploy.",
      "gridPos": { "x": 20, "y": 45, "w": 4, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "increase(traefik_config_reloads_total[24h])" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 306,
      "type": "row",
      "title": "Access-log analytics (Loki — enable `accessLog:` in traefik.yml to populate)",
      "collapsed": true,
      "gridPos": { "x": 0, "y": 51, "w": 24, "h": 1 },
      "panels": [
        {
          "id": 15,
          "type": "logs",
          "title": "Live log — reverse-proxy",
          "description": "Live tail of the Traefik container. Without `accessLog:` enabled this only shows operational logs (config reloads, internal errors).",
          "gridPos": { "x": 0, "y": 52, "w": 24, "h": 12 },
          "datasource": { "type": "loki", "uid": "loki" },
          "targets": [
            { "refId": "A", "expr": "{compose_service=\"reverse-proxy\"}" }
          ],
          "options": {
            "showTime": true,
            "showLabels": false,
            "showCommonLabels": false,
            "wrapLogMessage": true,
            "prettifyLogMessage": false,
            "enableLogDetails": true,
            "dedupStrategy": "none",
            "sortOrder": "Descending"
          }
        }
      ]
    },
    {
      "id": 309,
      "type": "row",
      "title": "FRPS — tunnel ingress (collapsed)",
      "collapsed": true,
      "gridPos": { "x": 0, "y": 52, "w": 24, "h": 1 },
      "panels": [
        {
          "id": 16,
          "type": "stat",
          "title": "Active connections",
          "description": "Current open connections on the FRP control channel. Metric names from FRP's prometheus.go — verify with `curl -s frps:7500/metrics | grep ^frps_` after first scrape.",
          "gridPos": { "x": 0, "y": 53, "w": 6, "h": 4 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            { "refId": "A", "expr": "frps_server_current_connections" }
          ],
          "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
          "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
        },
        {
          "id": 17,
          "type": "stat",
          "title": "Connected clients",
          "description": "Number of FRP clients currently registered with the server.",
          "gridPos": { "x": 6, "y": 53, "w": 6, "h": 4 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            { "refId": "A", "expr": "frps_server_client_counts" }
          ],
          "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
          "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
        },
        {
          "id": 18,
          "type": "stat",
          "title": "Registered proxies",
          "description": "Sum across proxy types (tcp / http / https / etc).",
