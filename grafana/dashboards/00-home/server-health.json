{
  "uid": "home-server-health",
  "title": "00-Home — Server health",
  "tags": ["homelab", "home"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "editable": false,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": {
    "list": [
      {
        "name": "Deploys",
        "datasource": { "type": "loki", "uid": "loki" },
        "enable": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "expr": "{compose_service=\"doco-cd\"} |~ \"(?i)deploy.*success\"",
        "target": {
          "expr": "{compose_service=\"doco-cd\"} |~ \"(?i)deploy.*success\"",
          "refId": "Anno"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 200,
      "type": "row",
      "title": "User-facing services",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Reverse proxy",
      "description": "Traefik scrape target health — `up{job=\"traefik\"}`. Green = Prometheus scraped successfully on the last attempt.",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "up{job=\"traefik\"}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ]
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "links": [
        { "title": "Open Traefik dashboard", "url": "/d/ingress-traefik", "targetBlank": false }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Authelia",
      "description": "Authelia liveness via Loki.",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum(count_over_time({compose_service=\"authelia\"}[5m])) > bool 0", "queryType": "instant" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }]
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Nextcloud",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum(count_over_time({compose_service=~\"nextcloud-(app|web)\"}[5m])) > bool 0", "queryType": "instant" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }]
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Vaultwarden",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum(count_over_time({compose_service=\"vaultwarden\"}[5m])) > bool 0", "queryType": "instant" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }]
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Plex",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum(count_over_time({compose_service=\"plex\"}[5m])) > bool 0", "queryType": "instant" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }]
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "AdGuard",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum(count_over_time({compose_service=\"adguard\"}[5m])) > bool 0", "queryType": "instant" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }]
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 201,
      "type": "row",
      "title": "Host headline",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "CPU %",
      "gridPos": { "x": 0, "y": 6, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 60 }, { "color": "red", "value": 85 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "links": [{ "title": "Host overview", "url": "/d/host-overview", "targetBlank": false }]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "RAM %",
      "gridPos": { "x": 4, "y": 6, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 75 }, { "color": "red", "value": 90 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Root free %",
      "description": "Free space on `/` as a percentage. Green > 30% free, orange 10–30%, red below.",
      "gridPos": { "x": 8, "y": 6, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "100 * (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 10 }, { "color": "green", "value": 30 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Temperature",
      "gridPos": { "x": 12, "y": 6, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "max(node_hwmon_temp_celsius)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 65 }, { "color": "red", "value": 80 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Load 1m / core",
      "gridPos": { "x": 16, "y": 6, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "node_load1 / count(node_cpu_seconds_total{mode=\"idle\"}) by (instance)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.7 }, { "color": "red", "value": 1.0 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "x": 20, "y": 6, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "time() - node_boot_time_seconds" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 202,
      "type": "row",
      "title": "Background-task health",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 1 }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Successful backups (24 h)",
      "description": "Count of borgmatic completion lines in the last 24 hours. Green > 0, red = 0 (backup missed). Will be replaced by `borgmatic_last_run_timestamp_seconds` once the node-exporter textfile-collector hook is in place.",
      "gridPos": { "x": 0, "y": 11, "w": 6, "h": 5 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum(count_over_time({compose_service=\"borgmatic\"} |~ \"(?i)summary.*errors:\\\\s*0|backup.*(complete|success)\" [24h]))", "queryType": "instant" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "links": [{ "title": "Borgmatic dashboard", "url": "/d/backups-borgmatic", "targetBlank": false }]
    },
    {
      "id": 16,
      "type": "stat",
      "title": "Traefik 5xx rate",
      "description": "Share of HTTP requests answered with a 5xx in the last 5 minutes. Green < 1 %, orange 1–5 %, red beyond. Hard threshold — this query becomes alert #10 unchanged.",
      "gridPos": { "x": 6, "y": 11, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(traefik_router_requests_total{code=~\"5..\"}[5m])) / sum(rate(traefik_router_requests_total[5m]))" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.01 }, { "color": "red", "value": 0.05 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "links": [{ "title": "Traefik dashboard", "url": "/d/ingress-traefik", "targetBlank": false }]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Errors/sec across all logs",
      "description": "Cross-project rate of log lines matching `error|panic|fatal` (case-insensitive). The shape matters more than the absolute number — a sustained step-up is the signal.",
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 5 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum by (compose_service) (rate({compose_project=\"my-whole-server\"} |~ \"(?i)error|panic|fatal\" [5m]))", "legendFormat": "{{compose_service}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "logs/sec",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 203,
      "type": "row",
      "title": "All services — 24 h uptime",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 1 }
    },
    {
      "id": 15,
      "type": "state-timeline",
      "title": "Service activity — last 24 h",
      "description": "One row per service. Green = container has produced log lines in the last 5 minutes; gap = silent (probably down, or simply idle if the service doesn't log much). Use as the closest thing to an alert log until Alertmanager exists.",
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum by (compose_service) (count_over_time({compose_project=\"my-whole-server\"}[5m])) > bool 0", "legendFormat": "{{compose_service}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "silent" }, "1": { "text": "alive" } } }]
        },
        "overrides": []
      },
      "options": { "mergeValues": true, "showValue": "never", "alignValue": "left", "rowHeight": 0.9, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false } }
    }
  ]
}
