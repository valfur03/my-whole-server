{
  "uid": "home-server-health",
  "title": "00-Home — Server health",
  "tags": ["homelab", "home"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "editable": false,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "links": [
    { "title": "Host",          "type": "link", "icon": "dashboard", "url": "/d/host-overview",          "tooltip": "10-Infra — Host overview",            "targetBlank": false, "keepTime": true, "includeVars": false },
    { "title": "Containers",    "type": "link", "icon": "dashboard", "url": "/d/infra-containers",       "tooltip": "10-Infra — Containers",               "targetBlank": false, "keepTime": true, "includeVars": false },
    { "title": "Traefik",       "type": "link", "icon": "dashboard", "url": "/d/ingress-traefik",        "tooltip": "20-Ingress — Traefik & FRPS",         "targetBlank": false, "keepTime": true, "includeVars": false },
    { "title": "Nextcloud",     "type": "link", "icon": "dashboard", "url": "/d/apps-nextcloud",         "tooltip": "30-Apps — Nextcloud",                 "targetBlank": false, "keepTime": true, "includeVars": false },
    { "title": "Seedbox",       "type": "link", "icon": "dashboard", "url": "/d/seedbox-transmission",   "tooltip": "40-Seedbox — Transmission & *arr",    "targetBlank": false, "keepTime": true, "includeVars": false },
    { "title": "Backups",       "type": "link", "icon": "dashboard", "url": "/d/backups-borgmatic",      "tooltip": "60-Backups — Borgmatic",              "targetBlank": false, "keepTime": true, "includeVars": false },
    { "title": "Observability", "type": "link", "icon": "dashboard", "url": "/d/observability-self",     "tooltip": "70-Observability — Self-monitoring",  "targetBlank": false, "keepTime": true, "includeVars": false },
    { "title": "Tracing",       "type": "link", "icon": "dashboard", "url": "/d/observability-tracing",  "tooltip": "70-Observability — Tracing",          "targetBlank": false, "keepTime": true, "includeVars": false }
  ],
  "annotations": {
    "list": [
      {
        "name": "Deploys",
        "datasource": { "type": "loki", "uid": "loki" },
        "enable": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "expr": "{compose_service=\"doco-cd\"} | json | msg=\"job completed successfully\" | elapsed_time > 10s",
        "target": {
          "expr": "{compose_service=\"doco-cd\"} | json | msg=\"job completed successfully\" | elapsed_time > 10s",
          "refId": "Anno"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 200,
      "type": "row",
      "title": "User-facing services",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Reverse proxy",
      "description": "Traefik liveness via blackbox probe to `/ping`. 1 = TLS handshake + HTTP 200 from Traefik's built-in healthcheck.",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "probe_success{instance=\"http://reverse-proxy:8080/ping\"}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ]
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "links": [
        { "title": "Open Traefik dashboard", "url": "/d/ingress-traefik", "targetBlank": false }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Authelia",
      "description": "Authelia liveness via blackbox probe to `/api/health` (returns 200 with `{status:\"OK\"}` when alive).",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "probe_success{instance=\"http://authelia:9091/api/health\"}" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }]
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "links": [
        { "title": "Open Ingress dashboard (Authelia is rolled into 20-Ingress)", "url": "/d/ingress-traefik", "targetBlank": false }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Nextcloud",
      "description": "Nextcloud liveness via blackbox probe to `/status.php` (JSON status endpoint, returns 200 when installed and reachable through nextcloud-web).",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "probe_success{instance=\"http://nextcloud-web:80/status.php\"}" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }]
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "links": [
        { "title": "Open Nextcloud dashboard", "url": "/d/apps-nextcloud", "targetBlank": false }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Vaultwarden",
      "description": "Vaultwarden liveness via blackbox probe to `/alive` (returns 200 with version JSON when up).",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "probe_success{instance=\"http://vaultwarden:80/alive\"}" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }]
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Plex",
      "description": "Plex liveness via blackbox probe to `/identity` (returns 200 with server XML when up — no auth required).",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "probe_success{instance=\"http://plex:32400/identity\"}" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }]
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "links": [
        { "title": "Open Seedbox dashboard (Plex panels land here per Section 3.8)", "url": "/d/seedbox-transmission", "targetBlank": false }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "AdGuard",
      "description": "AdGuard liveness via blackbox probe to AdGuard's web UI root.",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "probe_success{instance=\"http://adguard:80\"}" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }]
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 201,
      "type": "row",
      "title": "Host headline",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "CPU %",
      "gridPos": { "x": 0, "y": 6, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 60 }, { "color": "red", "value": 85 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "links": [{ "title": "Host overview", "url": "/d/host-overview", "targetBlank": false }]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "RAM %",
      "gridPos": { "x": 4, "y": 6, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 75 }, { "color": "red", "value": 90 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "links": [{ "title": "Host overview", "url": "/d/host-overview", "targetBlank": false }]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Root free %",
      "description": "Free space on `/` as a percentage. Green > 30% free, orange 10–30%, red below.",
      "gridPos": { "x": 8, "y": 6, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "100 * (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 10 }, { "color": "green", "value": 30 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "links": [{ "title": "Host overview", "url": "/d/host-overview", "targetBlank": false }]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Temperature",
      "gridPos": { "x": 12, "y": 6, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "max(node_hwmon_temp_celsius)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 65 }, { "color": "red", "value": 80 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "links": [{ "title": "Host overview", "url": "/d/host-overview", "targetBlank": false }]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Load 1m / core",
      "gridPos": { "x": 16, "y": 6, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "node_load1 / on(instance) count by (instance) (node_cpu_seconds_total{mode=\"idle\"})" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.7 }, { "color": "red", "value": 1.0 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "links": [{ "title": "Host overview", "url": "/d/host-overview", "targetBlank": false }]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "x": 20, "y": 6, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "time() - node_boot_time_seconds" }
      ],
      "fieldConfig": { "defaults": { "unit": "dtdurations", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "links": [{ "title": "Host overview", "url": "/d/host-overview", "targetBlank": false }]
    },
    {
      "id": 202,
      "type": "row",
      "title": "Background-task health",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 1 }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Time since last backup",
      "description": "Longest gap (across all borgmatic configs) since the last successful backup, from `borgmatic_last_success_timestamp_seconds` emitted by the node-exporter textfile-collector hook. Green < 24 h, yellow 24–48 h, red beyond — daily cadence means anything ≥ 24 h is a missed cycle.",
      "gridPos": { "x": 0, "y": 11, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "max(time() - borgmatic_last_success_timestamp_seconds)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 86400 }, { "color": "red", "value": 172800 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "links": [{ "title": "Borgmatic dashboard", "url": "/d/backups-borgmatic", "targetBlank": false }]
    },
    {
      "id": 16,
      "type": "stat",
      "title": "Traefik 5xx rate",
      "description": "Share of HTTP requests answered with a 5xx in the last 5 minutes. Green < 1 %, orange 1–5 %, red beyond. Hard threshold — this query becomes alert #10 unchanged.",
      "gridPos": { "x": 6, "y": 11, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(traefik_router_requests_total{code=~\"5..\"}[5m])) / sum(rate(traefik_router_requests_total[5m]))" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.01 }, { "color": "red", "value": 0.05 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "links": [{ "title": "Traefik dashboard", "url": "/d/ingress-traefik", "targetBlank": false }]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Errors/sec across all logs",
      "description": "Cross-project rate of log lines matching `error|panic|fatal` (case-insensitive). The shape matters more than the absolute number — a sustained step-up is the signal.",
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 5 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum by (compose_service) (rate({compose_project=\"my-whole-server\"} |~ \"(?i)error|panic|fatal\" [5m]))", "legendFormat": "{{compose_service}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "logs/sec",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 203,
      "type": "row",
      "title": "All services — 24 h uptime",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 1 }
    },
    {
      "id": 15,
      "type": "state-timeline",
      "title": "Service activity — last 24 h",
      "description": "One row per service. Green = container has produced log lines in the last 5 minutes; gap = silent (probably down, or simply idle if the service doesn't log much). Use as the closest thing to an alert log until Alertmanager exists.",
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum by (compose_service) (count_over_time({compose_project=\"my-whole-server\"}[5m])) > bool 0", "legendFormat": "{{compose_service}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "silent" }, "1": { "text": "alive" } } }]
        },
        "overrides": []
      },
      "options": { "mergeValues": true, "showValue": "never", "alignValue": "left", "rowHeight": 0.9, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false } }
    }
  ]
}
