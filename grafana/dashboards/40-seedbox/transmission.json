{
  "uid": "seedbox-transmission",
  "title": "40-Seedbox — Transmission & *arr",
  "tags": ["homelab", "seedbox", "transmission", "sonarr", "radarr"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "editable": false,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "torrent_name",
        "type": "textbox",
        "label": "Torrent name (regex)",
        "query": ".*",
        "current": { "selected": false, "text": ".*", "value": ".*" }
      },
      {
        "name": "state",
        "type": "custom",
        "label": "State",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "query": "Stopped : 0, Check wait : 1, Checking : 2, Download wait : 3, Downloading : 4, Seed wait : 5, Seeding : 6",
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "options": [
          { "selected": true, "text": "All", "value": "$__all" },
          { "selected": false, "text": "Stopped", "value": "0" },
          { "selected": false, "text": "Check wait", "value": "1" },
          { "selected": false, "text": "Checking", "value": "2" },
          { "selected": false, "text": "Download wait", "value": "3" },
          { "selected": false, "text": "Downloading", "value": "4" },
          { "selected": false, "text": "Seed wait", "value": "5" },
          { "selected": false, "text": "Seeding", "value": "6" }
        ]
      },
      {
        "name": "torrent",
        "type": "query",
        "label": "Single torrent (drill-down)",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "qryType": 1, "query": "label_values(transmission_torrent_status, name)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "definition": "label_values(transmission_torrent_status, name)",
        "regex": "",
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "current": { "selected": false, "text": "", "value": "" }
      }
    ]
  },
  "links": [
    { "title": "Home", "type": "link", "icon": "home", "url": "/d/home-server-health", "tooltip": "00-Home — Server health", "targetBlank": false, "keepTime": true, "includeVars": false }
  ],
  "annotations": {
    "list": [
      {
        "name": "Deploys",
        "datasource": { "type": "loki", "uid": "loki" },
        "enable": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "expr": "{compose_service=\"doco-cd\"} |~ \"(?i)deploy.*success\"",
        "target": {
          "expr": "{compose_service=\"doco-cd\"} |~ \"(?i)deploy.*success\"",
          "refId": "Anno"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Counts",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Total",
      "description": "Number of torrents Transmission knows about.",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "count(transmission_torrent_status)" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Downloading",
      "description": "State 4 (downloading) plus state 3 (download wait).",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "count(transmission_torrent_status == 4) or vector(0)" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Seeding",
      "description": "State 6 (seeding).",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "count(transmission_torrent_status == 6) or vector(0)" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Idle / paused",
      "description": "States 1, 2, 3, 5 — waiting / checking.",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "count(transmission_torrent_status == 1 or transmission_torrent_status == 2 or transmission_torrent_status == 3 or transmission_torrent_status == 5) or vector(0)" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "yellow" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Stopped",
      "description": "State 0.",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "count(transmission_torrent_status == 0) or vector(0)" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Matching filter",
      "description": "Torrents matching the current `$torrent_name` regex and `$state` selection.",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "count(transmission_torrent_status{name=~\"$torrent_name\", status=~\"$state\"}) or vector(0)" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 101,
      "type": "row",
      "title": "Section A — Find a torrent (filterable table)",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Torrents — sortable & filterable",
      "description": "One row per torrent matching the variables above. Sorted by uploaded-total desc. Click a row to copy the torrent name, then paste into the `$torrent` variable above to drill down in Section B. Metric names are best-effort against metalmatze/transmission-exporter — verify with `curl transmission-exporter:19091/metrics | sort -u`.",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "Ratio",
          "expr": "transmission_torrent_ratio{name=~\"$torrent_name\"}",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "Done",
          "expr": "transmission_torrent_done{name=~\"$torrent_name\"}",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "Size",
          "expr": "transmission_torrent_total_size{name=~\"$torrent_name\"}",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "Uploaded",
          "expr": "transmission_torrent_uploaded_ever{name=~\"$torrent_name\"}",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "UpSpeed",
          "expr": "transmission_torrent_upload_bytes{name=~\"$torrent_name\"}",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "Status",
          "expr": "transmission_torrent_status{name=~\"$torrent_name\", status=~\"$state\"}",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "Added",
          "expr": "transmission_torrent_added{name=~\"$torrent_name\"} * 1000",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "name", "mode": "outer" }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": ["name", "Value #Status", "Value #Done", "Value #Ratio", "Value #Size", "Value #Uploaded", "Value #UpSpeed", "Value #Added"]
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "name": "Name",
              "Value #Status": "State",
              "Value #Done": "Progress",
              "Value #Ratio": "Ratio",
              "Value #Size": "Size",
              "Value #Uploaded": "Up total",
              "Value #UpSpeed": "Up rate",
              "Value #Added": "Added"
            },
            "indexByName": {
              "Name": 0,
              "State": 1,
              "Progress": 2,
              "Ratio": 3,
              "Size": 4,
              "Up total": 5,
              "Up rate": 6,
              "Added": 7
            }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": {}, "sort": [{ "field": "Up total", "desc": true }] }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Progress" }, "properties": [{ "id": "unit", "value": "percentunit" }, { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } }, { "id": "min", "value": 0 }, { "id": "max", "value": 1 }] },
          { "matcher": { "id": "byName", "options": "Ratio" }, "properties": [{ "id": "unit", "value": "short" }, { "id": "decimals", "value": 2 }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 1 }] } }, { "id": "custom.cellOptions", "value": { "type": "color-text" } }] },
          { "matcher": { "id": "byName", "options": "Size" }, "properties": [{ "id": "unit", "value": "bytes" }] },
          { "matcher": { "id": "byName", "options": "Up total" }, "properties": [{ "id": "unit", "value": "bytes" }] },
          { "matcher": { "id": "byName", "options": "Up rate" }, "properties": [{ "id": "unit", "value": "Bps" }] },
          { "matcher": { "id": "byName", "options": "Added" }, "properties": [{ "id": "unit", "value": "dateTimeAsIso" }] },
          {
            "matcher": { "id": "byName", "options": "State" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "Stopped", "color": "red" }, "1": { "text": "Check wait", "color": "yellow" }, "2": { "text": "Checking", "color": "yellow" }, "3": { "text": "DL wait", "color": "yellow" }, "4": { "text": "Downloading", "color": "orange" }, "5": { "text": "Seed wait", "color": "yellow" }, "6": { "text": "Seeding", "color": "green" } } }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": { "show": false }
      }
    },
    {
      "id": 102,
      "type": "row",
      "title": "Section B — Per-torrent drill-down (uses $torrent variable)",
      "collapsed": true,
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 1 },
      "panels": [
        {
          "id": 8,
          "type": "stat",
          "title": "Ratio ($torrent)",
          "gridPos": { "x": 0, "y": 21, "w": 6, "h": 4 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            { "refId": "A", "expr": "transmission_torrent_ratio{name=\"$torrent\"}" }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "decimals": 2,
              "color": { "mode": "thresholds" },
              "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 1 }] }
            },
            "overrides": []
          },
          "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
        },
        {
          "id": 9,
          "type": "stat",
          "title": "Total uploaded",
          "gridPos": { "x": 6, "y": 21, "w": 6, "h": 4 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            { "refId": "A", "expr": "transmission_torrent_uploaded_ever{name=\"$torrent\"}" }
          ],
          "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
          "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
        },
        {
          "id": 10,
          "type": "stat",
          "title": "Total size",
          "description": "Total size of the torrent. The exporter does not expose a cumulative downloaded-bytes counter, so size is shown here instead.",
          "gridPos": { "x": 12, "y": 21, "w": 6, "h": 4 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            { "refId": "A", "expr": "transmission_torrent_total_size{name=\"$torrent\"}" }
          ],
          "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
          "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
        },
        {
          "id": 11,
          "type": "stat",
          "title": "Peers",
          "gridPos": { "x": 18, "y": 21, "w": 6, "h": 4 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            { "refId": "A", "expr": "transmission_torrent_peers_connected{name=\"$torrent\"}" }
          ],
          "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
          "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
        },
        {
          "id": 12,
          "type": "timeseries",
          "title": "Upload rate — last 7 days",
          "description": "Single-series view of one torrent over a long range. Bursts and seeding gaps are legible.",
          "gridPos": { "x": 0, "y": 25, "w": 24, "h": 8 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            { "refId": "A", "expr": "transmission_torrent_upload_bytes{name=\"$torrent\"}", "legendFormat": "up" }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "Bps",
              "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20, "showPoints": "never" }
            },
            "overrides": []
          },
          "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false }, "tooltip": { "mode": "single", "sort": "none" } }
        },
        {
          "id": 13,
          "type": "state-timeline",
          "title": "State over time",
          "description": "Status timeline for the single selected torrent.",
          "gridPos": { "x": 0, "y": 33, "w": 24, "h": 5 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            { "refId": "A", "expr": "transmission_torrent_status{name=\"$torrent\"}", "legendFormat": "state" }
          ],
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "mappings": [
                {
                  "type": "value",
                  "options": {
                    "0": { "text": "Stopped", "color": "red" },
                    "1": { "text": "Check wait", "color": "yellow" },
                    "2": { "text": "Checking", "color": "yellow" },
                    "3": { "text": "DL wait", "color": "yellow" },
                    "4": { "text": "Downloading", "color": "orange" },
                    "5": { "text": "Seed wait", "color": "yellow" },
                    "6": { "text": "Seeding", "color": "green" }
                  }
                }
              ]
            },
            "overrides": []
          },
          "options": { "mergeValues": true, "showValue": "auto", "alignValue": "left", "rowHeight": 0.9 }
        }
      ]
    },
    {
      "id": 103,
      "type": "row",
      "title": "Section C — Aggregate patterns",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 38, "w": 24, "h": 1 }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Total upload rate",
      "description": "Sum of `transmission_torrent_upload_bytes` across all torrents — current 'am I seeding right now?' signal.",
      "gridPos": { "x": 0, "y": 39, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(transmission_torrent_upload_bytes)" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Total download rate",
      "gridPos": { "x": 6, "y": 39, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(transmission_torrent_download_bytes)" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 16,
      "type": "stat",
      "title": "Overall ratio",
      "description": "Average of per-torrent ratios. The exporter does not expose a cumulative downloaded-bytes counter, so a true sum(uploaded)/sum(downloaded) is not available — this is an unweighted approximation.",
      "gridPos": { "x": 12, "y": 39, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "avg(transmission_torrent_ratio)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 17,
      "type": "stat",
      "title": "Active torrents",
      "description": "Torrents currently uploading or downloading (status 4 or 6).",
      "gridPos": { "x": 18, "y": 39, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "count(transmission_torrent_upload_bytes > 0 or transmission_torrent_download_bytes > 0) or vector(0)" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Total throughput (up + down)",
      "description": "Aggregate of all torrent up/down speeds.",
      "gridPos": { "x": 0, "y": 43, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(transmission_torrent_upload_bytes)", "legendFormat": "upload" },
        { "refId": "B", "expr": "sum(transmission_torrent_download_bytes)", "legendFormat": "download" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 15, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 31,
      "type": "state-timeline",
      "title": "Upload activity — which torrent uploaded when",
      "description": "One row per torrent, X = time, colour = upload-rate bucket. Reads like the original heatmap idea but uses State Timeline because Grafana heatmaps require numeric Y buckets, not torrent names. Horizontal coloured band = a torrent that seeded consistently; vertical stripe across many rows = a moment when many torrents got peer interest. Capped to the 40 currently-active torrents (upload > 0) per scrape — narrow further with `$torrent_name`.",
      "gridPos": { "x": 0, "y": 51, "w": 24, "h": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(40, transmission_torrent_upload_bytes{name=~\"$torrent_name\", status=~\"$state\"} > 0)",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "#3274d9", "value": 1 },
              { "color": "#56a64b", "value": 102400 },
              { "color": "#f2cc0c", "value": 1048576 },
              { "color": "#e02f44", "value": 10485760 }
            ]
          },
          "noValue": "idle"
        },
        "overrides": []
      },
      "options": {
        "mergeValues": false,
        "showValue": "never",
        "alignValue": "left",
        "rowHeight": 0.9,
